<UserControl x:Class="MangaStudio.UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MangaStudio.UI.Converters">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource SurfaceBrush}">
        <StackPanel Margin="28" MaxWidth="820">

            <!-- ── Manga Folders ── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Manga Folders"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Add one or more manga root folders. Each folder is scanned for chapter subfolders."
                       Margin="0,0,0,10" TextWrapping="Wrap"/>

            <Border Style="{StaticResource Card}" Padding="0">
                <ListBox ItemsSource="{Binding FolderList}"
                         SelectedItem="{Binding SelectedFolder}"
                         Height="160"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Padding="12,6"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentLightBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="＋  Add Folder"
                        Command="{Binding AddFolderCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"/>
                <Button Content="✕  Remove Selected"
                        Command="{Binding RemoveFolderCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>

            <!-- ── Output Path ── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Output Folder" Margin="0,28,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                         Grid.Column="0"
                         Margin="0,0,8,0"/>
                <Button Content="Browse"
                        Command="{Binding BrowseOutputCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Grid.Column="1"/>
            </Grid>

            <!-- ── Quality ── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Output Quality (WebP)" Margin="0,28,0,6"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Overrides the default quality for this session only."
                       Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="400"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Minimum="1" Maximum="100"
                        Value="{Binding Quality}"
                        VerticalAlignment="Center"
                        Grid.Column="0"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="{Binding Quality, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>
            </Grid>

            <!-- ── Start / Cancel ── -->
            <StackPanel Orientation="Horizontal" Margin="0,28,0,0">
                <Button Content="▶  Start Processing"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="160"
                        Margin="0,0,10,0"/>
                <Button Content="■  Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource DangerButton}"
                        Width="90"/>
            </StackPanel>

            <!-- ── Progress ── -->
            <ProgressBar Value="{Binding ProgressValue, Mode=OneWay}"
             Maximum="{Binding ProgressMax, Mode=OneWay}"
             Height="6"
             Margin="0,20,0,6"/>

            <TextBlock Text="{Binding StatusText}"
                       FontSize="13"
                       Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock Text="{Binding CurrentChapter}"
                       Style="{StaticResource HintText}"
                       Margin="0,2,0,0"
                       TextTrimming="CharacterEllipsis"/>

            <!-- ── Summary ── -->
            <Border Background="{StaticResource AccentLightBrush}"
                    CornerRadius="6"
                    Padding="14,10"
                    Margin="0,14,0,0"
                    Visibility="{Binding SummaryText,Converter={x:Static converters:StringToVisibilityConverter.Instance}}">
                <TextBlock Text="{Binding SummaryText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>