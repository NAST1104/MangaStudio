<Window x:Class="MangaStudio.UI.Views.SummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processing Summary"
        Width="620" Height="520"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Stat cards ── -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel Orientation="Horizontal">

                <Border Background="#DCFCE7" CornerRadius="8" Padding="20,12" Margin="0,0,12,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SucceededCount}"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="#166534" HorizontalAlignment="Center"/>
                        <TextBlock Text="Succeeded"
                                   FontSize="12" Foreground="#166534" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#FEF9C3" CornerRadius="8" Padding="20,12" Margin="0,0,12,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SkippedCount}"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="#854D0E" HorizontalAlignment="Center"/>
                        <TextBlock Text="Skipped"
                                   FontSize="12" Foreground="#854D0E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#FEE2E2" CornerRadius="8" Padding="20,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding FailedCount}"
                                   FontSize="28" FontWeight="SemiBold"
                                   Foreground="#991B1B" HorizontalAlignment="Center"/>
                        <TextBlock Text="Failed"
                                   FontSize="12" Foreground="#991B1B" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ── Chapter list ── -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Results}"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"         Value="20,0"/>
                    <Setter Property="Background"      Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Status icon -->
                            <TextBlock Grid.Column="0"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Text="{Binding StatusIcon}"/>

                            <!-- Chapter name + error -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Result.ChapterName}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Result.ErrorMessage}"
                                           FontSize="11"
                                           Foreground="#DC2626"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding HasError,
                                               Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding Result.IsSkipped,
                                               Converter={StaticResource BoolToVisibility}}">
                                    Output already existed — skipped
                                </TextBlock>
                            </StackPanel>

                            <!-- File count -->
                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"
                                       Text="{Binding FileCountText}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Buttons ── -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open Output Folder"
                        Click="OpenOutputFolder_Click"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>
                <Button Content="Close"
                        Click="Close_Click"
                        Style="{StaticResource PrimaryButton}"
                        Width="80"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>