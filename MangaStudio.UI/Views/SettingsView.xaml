<UserControl x:Class="MangaStudio.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MangaStudio.UI.Converters">

    <UserControl.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource SurfaceBrush}">
        <StackPanel Margin="28" MaxWidth="640">

            <!-- ── Imaging Backend ── -->
            <TextBlock Style="{StaticResource SectionHeader}" Text="Imaging Backend"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="libvips is significantly faster for large images. ImageSharp is the safe fallback."
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <ComboBox ItemsSource="{Binding AvailableBackends}"
                      SelectedItem="{Binding Backend}"
                      Width="200"
                      HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding BackendNote}"
                       Style="{StaticResource HintText}"
                       Margin="0,6,0,0"/>

            <!-- ── Output Format ── -->
            <TextBlock Style="{StaticResource SectionHeader}"
                       Text="Output Format" Margin="0,28,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                <!-- WebP card -->
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,12,0"
                        Width="270">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton GroupName="Format"
                                         VerticalAlignment="Center"
                                         IsChecked="{Binding OutputFormat,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter=WebP}"/>
                            <TextBlock Text="WebP"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Best compression. Hard limit: 15,000px height."
                                   Style="{StaticResource HintText}"
                                   TextWrapping="Wrap"
                                   Margin="22,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- JPEG card -->
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Width="270">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton GroupName="Format"
                                         VerticalAlignment="Center"
                                         IsChecked="{Binding OutputFormat,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter=Jpg}"/>
                            <TextBlock Text="JPEG"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="No height limit. Best for tall manhua chapters."
                                   Style="{StaticResource HintText}"
                                   TextWrapping="Wrap"
                                   Margin="22,0,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Format note -->
            <Border Background="{StaticResource AccentLightBrush}"
                    CornerRadius="6"
                    Padding="12,8"
                    Margin="0,0,0,0">
                <TextBlock Text="{Binding FormatNote}"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- ── Max Stitch Height ── -->
            <TextBlock Style="{StaticResource SectionHeader}"
                       Text="Max Stitch Height (px)" Margin="0,28,0,6"/>
            <TextBlock Text="{Binding MaxStitchHeightNote}"
                       Style="{StaticResource HintText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>
            <TextBox Text="{Binding MaxStitchHeight, UpdateSourceTrigger=PropertyChanged}"
                     Width="160"
                     HorizontalAlignment="Left"/>

            <!-- ── Default Quality ── -->
            <TextBlock Style="{StaticResource SectionHeader}"
                       Text="Default Quality" Margin="0,28,0,6"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Used as the starting value on the Home tab. Can be overridden per session."
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="380"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider Minimum="1" Maximum="100"
                        Value="{Binding DefaultQuality}"
                        VerticalAlignment="Center"
                        Grid.Column="0"/>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="{Binding DefaultQuality, Mode=OneWay}"/><Run Text="%"/>
                </TextBlock>
            </Grid>

            <!-- ── Delete Originals ── -->
            <TextBlock Style="{StaticResource SectionHeader}"
                       Text="After Processing" Margin="0,28,0,8"/>
            <CheckBox Content="Delete original chapter folders after successful processing"
                      IsChecked="{Binding DeleteOriginals}"/>
            <TextBlock Style="{StaticResource HintText}"
                       Text="Warning: permanently removes source images. Verify your output path before enabling."
                       TextWrapping="Wrap"
                       Margin="20,4,0,0"/>

            <!-- ── Duplicate Chapters ── -->
            <TextBlock Style="{StaticResource SectionHeader}"
           Text="Existing Output Chapters" Margin="0,28,0,6"/>
            <TextBlock Style="{StaticResource HintText}"
           Text="What to do when a chapter's output folder already exists."
           TextWrapping="Wrap" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">

                <!-- Skip card -->
                <Border Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Margin="0,0,12,0"
            Width="270">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton GroupName="DupAction"
                             VerticalAlignment="Center"
                             IsChecked="{Binding DuplicateAction,
                                 Converter={StaticResource EnumToBool},
                                 ConverterParameter=Skip}"/>
                            <TextBlock Text="Skip"
                           FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Leave existing output untouched and move on."
                       Style="{StaticResource HintText}"
                       TextWrapping="Wrap" Margin="22,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Overwrite card -->
                <Border Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Width="270">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton GroupName="DupAction"
                             VerticalAlignment="Center"
                             IsChecked="{Binding DuplicateAction,
                                 Converter={StaticResource EnumToBool},
                                 ConverterParameter=Overwrite}"/>
                            <TextBlock Text="Overwrite"
                           FontWeight="SemiBold" FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Delete existing output and reprocess the chapter."
                       Style="{StaticResource HintText}"
                       TextWrapping="Wrap" Margin="22,0,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── Reset ── -->
            <Button Content="Reset to Defaults"
                    Command="{Binding ResetCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Left"
                    Margin="0,28,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>