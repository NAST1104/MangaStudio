<Window x:Class="MangaStudio.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MangaStudio.UI"
        mc:Ignorable="d"
        Title="MangaStudio" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="MangaStudio"
                       FontSize="32" FontWeight="Light"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Phase 1 — Skeleton ready"
                       FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</Window>
