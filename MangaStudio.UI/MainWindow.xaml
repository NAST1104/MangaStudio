<Window x:Class="MangaStudio.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MangaStudio.UI.Views"
        Title="MangaStudio"
        Height="680" Width="980"
        MinHeight="560" MinWidth="780"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Title bar ── -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,12">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="MangaStudio"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Long-strip processor"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                </StackPanel>

                <Button Content="About"
                        Click="About_Click"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Right"
                        Padding="14,5"/>
            </Grid>
        </Border>

        <!-- ── Tabs ── -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize"   Value="13"/>
                    <Setter Property="Padding"    Value="20,10"/>
                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabItem Header="Home">
                <views:HomeView DataContext="{Binding Home}"/>
            </TabItem>
            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}"/>
            </TabItem>
            <TabItem Header="History">
                <views:HistoryView DataContext="{Binding History}"/>
            </TabItem>
            <TabItem Header="Logs">
                <views:LogView DataContext="{Binding Logs}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>